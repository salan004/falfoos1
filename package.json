{
  "name": "discord-meme-bot",
  "version": "1.0.0",
  "description": "A modern, production-ready Discord meme bot with voting, favorites, leaderboards, and auto-posting",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "deploy:commands": "tsx src/deploy-commands.ts",
    "docker:build": "docker build -t discord-meme-bot .",
    "docker:run": "docker-compose up -d",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop ecosystem.config.js",
    "pm2:logs": "pm2 logs meme-bot",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "discord",
    "meme-bot",
    "discord.js",
    "typescript"
  ],
  "license": "MIT",
  "dependencies": {
    "canvas": "^3.2.3",
    "discord.js": "^14.18.0",
    "dotenv": "^16.4.7",
    "node-fetch": "^2.7.0",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/node-fetch": "^2.6.12",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
